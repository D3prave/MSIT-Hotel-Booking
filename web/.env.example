# Required
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT_REF.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY

# Admin dashboard access (comma-separated list)
ADMIN_EMAILS=admin@example.com

# Email notifications (recommended for no-domain setup: Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=your-mailbox@gmail.com
SMTP_PASS=your_16_char_gmail_app_password
EMAIL_FROM=DENKRAUM 1886 <your-mailbox@gmail.com>

# Optional testing override: routes all outgoing booking emails here
EMAIL_TEST_TO=

# Optional fallback provider (Resend)
RESEND_API_KEY=
RESEND_FROM_EMAIL=
RESEND_TEST_TO=
